name: Build InventorySync

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    - uses: actions/checkout@v3
    
    - name: Set up JDK 8
      uses: actions/setup-java@v3
      with:
        java-version: '8'
        distribution: 'temurin'
    
    - name: Build with Maven
      run: mvn -B clean package -DskipTests
    
    - name: Upload JAR
      uses: actions/upload-artifact@v3
      with:
        name: InventorySync
        path: target/InventorySync-1.0.0.jar
